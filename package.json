{
  "name": "@swtiit/ekip",
  "version": "0.4.0",
  "description": "Assemble an ekip (\u00ea-k\u00edp \u2014 a tight-knit working crew) of coding agents: Claude Code, Antigravity, and any headless CLI delegate tasks and share context over MCP.",
  "type": "module",
  "bin": {
    "ekip": "dist/cli/index.js",
    "agent-bridge": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/core/index.js",
    "./protocol": "./dist/protocol/index.js"
  },
  "files": [
    "dist",
    "examples",
    "PROTOCOL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "serve": "node dist/cli/index.js serve",
    "test": "node test/e2e.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "agents",
    "claude-code",
    "antigravity",
    "orchestration",
    "multi-agent"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swtiit/ekip.git"
  },
  "homepage": "https://github.com/swtiit/ekip#readme",
  "bugs": {
    "url": "https://github.com/swtiit/ekip/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}